# 1. Copy this file to the same folder and name it:  .env   (not .env.example)
# 2. Put your key on the line below (no spaces around =). Restart: npm run dev
# 3. Key is read from tutor-app/.env even if you run vite from the parent repo folder.
OPENAI_API_KEY=

# ElevenLabs: озвучка словаря (мультиязычная). Без ключа TTS отключён.
# ELEVENLABS_VOICE_ID — необязательно; если пусто, используется мужской пресет Adam.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Путь к PDF: Феерштейн / Старец — «Большой португальско-русский словарь» (вкладка «Большой словарь»).
# Пример Windows: BIG_PT_RU_DICT_PDF=e:/MEDIA/Books/.../....pdf
BIG_PT_RU_DICT_PDF=
